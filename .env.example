# LLM providers (native env names — loaded via python-dotenv when using --summary)
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# MISTRAL_API_KEY=
# OPENROUTER_API_KEY=

# Optional: local Ollama (no API key required for local models)
# OLLAMA_API_BASE=http://localhost:11434

# HTTP fetch timeout in ms (default: 10000)
# AI_CONTEXT_FETCH_TIMEOUT=10000

# Max content size in bytes before truncation (default: 2MB)
# AI_CONTEXT_MAX_CONTENT_SIZE=2097152
